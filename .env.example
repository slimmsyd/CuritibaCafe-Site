# Copy this file to .env.local and fill in your keys.
# .env* is gitignored — never commit real keys.

# --- Stripe (required for checkout) ---------------------------------------
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook signing secret. Local dev: run
#   stripe listen --forward-to localhost:3000/api/webhooks/stripe
# and copy the printed whsec_... here. Production: set it from the webhook
# endpoint you create in the Stripe dashboard.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Optional integrations -------------------------------------------------
# Where to forward an order after payment succeeds (Zapier/Make/n8n/your API).
# Leave blank to just log orders to the server console.
ORDER_WEBHOOK_URL=

# Where to forward free-chapter email signups (Mailchimp/ConvertKit/your API).
# Leave blank to just log signups to the server console.
EMAIL_WEBHOOK_URL=

# Public site URL, used for SEO/OpenGraph metadata + absolute links.
# Leave unset in local dev (defaults to http://localhost:3000).
# e.g. https://yourdomain.com
# NEXT_PUBLIC_SITE_URL=

# Google Analytics measurement ID (e.g. G-XXXXXXXXXX). Leave blank to ship
# without analytics — no script is injected when this is unset.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Google Places reviews (OPTIONAL) --------------------------------------
# Shows live top-5 Google reviews in the "What people say" section. Leave blank
# and the section falls back to the curated quotes in site-data.ts.
# The key must have "Places API (New)" enabled and must NOT be restricted to
# HTTP referrers (this call runs server-side) — restrict by IP or leave open.
# https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=
# Optional: set the exact Place ID to skip the text lookup (one fewer call).
# Find it at https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACE_ID=

# --- Resend email (OPTIONAL) -----------------------------------------------
# Set ALL THREE to send order receipts + free-chapter welcome emails (and admin
# alerts) on purchase/signup. Requires the DATABASE_URL below (emails read the
# persisted order/subscriber). Leave any blank and email sends are skipped.
# Get an API key at https://resend.com/api-keys and verify your sending domain.
RESEND_API_KEY=
# Verified sender, "Display Name <you@yourdomain.com>"
RESEND_FROM_EMAIL=
# Inbox that receives the purchase + signup admin alerts.
ADMIN_NOTIFICATION_EMAIL=

# --- Admin CRM (OPTIONAL) --------------------------------------------------
# Leave ALL THREE of these blank and the template runs exactly as before:
# static site.config, no /admin, no database. Set all three to turn the CRM on
# (edit content in the browser, persist orders + subscribers). Then run:
#   npm run db:init
#
# Neon Postgres connection string (neon.tech). Enables the database.
DATABASE_URL=
# Signs the admin session cookie. Generate: openssl rand -hex 32
SESSION_SECRET=
# Admin login password. In production prefer ADMIN_PASSWORD_HASH and omit this.
# Hash: node -e "console.log(require('crypto').createHash('sha256').update(process.argv[1]).digest('hex'))" 'yourpassword'
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH=    # sha256 hex; if set, takes precedence over ADMIN_PASSWORD
